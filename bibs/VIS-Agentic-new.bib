}

@article{jia2025VOICEVisualOracle,
  title = {{{VOICE}}: {{Visual Oracle}} for {{Interaction}}, {{Conversation}}, and {{Explanation}}},
  shorttitle = {{{VOICE}}},
  author = {Jia, Donggang and Irger, Alexandra and Besançon, Lonni and Strnad, Ondřej and Luo, Deng and Björklund, Johanna and Kouyoumdjian, Alexandre and Ynnerman, Anders and Viola, Ivan},
  date = {2025-10},
  journaltitle = {IEEE Transactions on Visualization and Computer Graphics},
