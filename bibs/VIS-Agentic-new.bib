  file = {files/3077/Li et al. - 2025 - Why is AI Not a Panacea for Data Workers An Interview Study on Human-AI Collaboration in Data Story.pdf}
}

@article{liu2024AVAAutonomousVisualization,
  title = {{{AVA}}: {{Towards Autonomous Visualization Agents}} through {{Visual Perception-Driven Decision-Making}}},
  shorttitle = {{{AVA}}},
  author = {Liu, S. and Miao, H. and Li, Z. and Olson, M. and Pascucci, V. and Bremer, P-T.},
